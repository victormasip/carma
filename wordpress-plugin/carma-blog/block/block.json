{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "carma/blog",
	"version": "0.1.0",
	"title": "Carma Blog",
	"category": "embed",
	"icon": "rss",
	"description": "Show your Carma blog on this page. The feed renders in an isolated Shadow DOM, so it looks perfect regardless of your theme's CSS.",
	"keywords": [ "carma", "blog", "feed", "posts", "articles" ],
	"textdomain": "carma-blog",
	"attributes": {
		"siteId": {
			"type": "string",
			"default": ""
		},
		"feed": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"cols": {
			"type": "string",
			"default": ""
		}
	},
	"example": {
		"attributes": {}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css"
}
